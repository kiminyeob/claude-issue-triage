# Line endings: shell scripts MUST stay LF (CRLF breaks bash: "\r: command not found"),
# even when cloned on Windows with core.autocrlf=true.
* text=auto
*.sh text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
# PowerShell is fine either way; keep CRLF as the Windows convention.
*.ps1 text eol=crlf
